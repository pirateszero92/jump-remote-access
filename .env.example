# Copy to .env and adjust before first run:
#   cp .env.example .env        (Linux/macOS)
#   copy .env.example .env      (Windows)
#
# Docker Compose reads this file for ${VAR} substitution in docker-compose.yml.
# Local `npm start` loads it via dotenv in server.js.

# --- HTTP server ---
# Listen port for the Jump UI and API
PORT=8080

# Directory for targets.json and tokens.cfg (use ./data when running locally)
DATA_DIR=./data

# --- Login (Jump UI) ---
# Change before production
APP_USER=admin
APP_PASS=password

# Session signing secret (32+ random hex chars recommended).
# If omitted, a new random secret is generated on each restart (sessions reset).
APP_SECRET=change-this-to-a-long-random-string

# --- VNC / websockify ---
# Where Node proxies /websockify (in Docker: websockify on localhost inside the container)
WEBSOCKIFY_TARGET=http://127.0.0.1:6080

# VNC token lifetime in milliseconds (default 6 hours = 21600000)
TOKEN_TTL_MS=21600000

# --- RDP (guacd + guacamole-lite) ---
GUACD_HOST=127.0.0.1
GUACD_PORT=4822

# Internal WebSocket port for guacamole-lite (usually no need to change)
GUACAMOLE_WS_PORT=4824

# AES key for Guacamole tokens: exactly 32 characters, or leave unset to derive from APP_SECRET
GUACAMOLE_CRYPT_KEY=JumpRemoteDesktopCryptKey2026!!

# --- SSH bridge ---
# Default idle disconnect shown in the UI (milliseconds; 900000 = 15 minutes)
SSH_DEFAULT_IDLE_TIMEOUT_MS=900000

# Min/max idle timeout the UI may request (milliseconds)
SSH_MIN_IDLE_TIMEOUT_MS=60000
SSH_MAX_IDLE_TIMEOUT_MS=43200000

# SSH transport keepalive (disconnect after interval * count without response)
SSH_KEEPALIVE_INTERVAL_MS=20000
SSH_KEEPALIVE_COUNT_MAX=4

# Max wait for SSH handshake to complete (milliseconds)
SSH_READY_TIMEOUT_MS=15000
